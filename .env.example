DATABASE_URL="postgresql://user:password@host:5432/le_rempart?sslmode=require"

# Mot de passe unique pour /admin
ADMIN_PASSWORD="change-me"

# Secret long et aléatoire pour signer le cookie de session
ADMIN_SESSION_SECRET="change-me-to-a-long-random-string"

# Clé API Moonshot AI (Kimi) — https://platform.moonshot.ai
MOONSHOT_API_KEY=""

# URL publique du site (liens dans Telegram / Facebook)
NEXT_PUBLIC_SITE_URL="https://le-rempart.org"

# Bot Telegram (@rempartbot)
TELEGRAM_BOT_TOKEN=""
TELEGRAM_ALLOWED_USER_IDS=""

# Unsplash (illustration site) — https://unsplash.com/oauth/applications
UNSPLASH_ACCESS_KEY=""

# Facebook Page (post créative + commentaire épinglé)
FACEBOOK_PAGE_ID=""
FACEBOOK_PAGE_ACCESS_TOKEN=""

# Optionnel — AdSense
# NEXT_PUBLIC_ADSENSE_CLIENT="ca-pub-xxxxxxxxxxxxxxxx"
